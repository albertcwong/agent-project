# Agent backend config (Python). Copy to .env.agent and configure.
# The agent loads .env.agent when started via `npm run agent`.

# LLM proxy (for agent loop)
LLM_PROXY_URL=http://localhost:8000
LLM_PROXY_API_KEY=
LLM_PROXY_PROVIDER=openai

# Tableau MCP: JSON array of {id, name, url, token?, oauthEnabled?, authType?}
# token: only if MCP HTTP endpoint requires client auth (PAT servers typically use their own env)
# oauthEnabled: false or authType: "pat" = skip OAuth (MCP server uses its own PAT from its env)
# In Docker: use host.docker.internal instead of localhost (callback runs in container)
TABLEAU_MCP_SERVERS='[{"id":"production","name":"Production","url":"http://localhost:3927/tableau-mcp","token":"YOUR_ACCESS_TOKEN","oauthEnabled":false}]'

# Agent loop (Executive Brief workflow needs ~9 iterations)
MAX_AGENT_ITERATIONS=20
DEFAULT_MODEL=gpt-4

# LLM stream read timeout (seconds) - increase if streams are cut off
# LLM_STREAM_READ_TIMEOUT=300
