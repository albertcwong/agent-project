# Agent backend config (Python). Copy to .env.agent and configure.
# The agent loads .env.agent when started via `npm run agent`.

# LLM proxy (for agent loop)
LLM_PROXY_URL=http://localhost:8000
LLM_PROXY_API_KEY=
LLM_PROXY_PROVIDER=openai

# Tableau MCP: JSON array of {id, name, url, token?}
# token: optional Bearer token for OAuth-protected servers
TABLEAU_MCP_SERVERS='[{"id":"production","name":"Production","url":"http://localhost:3927/tableau-mcp","token":"YOUR_ACCESS_TOKEN"}]'

# Agent loop
MAX_AGENT_ITERATIONS=10
DEFAULT_MODEL=gpt-4

# LLM stream read timeout (seconds) - increase if streams are cut off
# LLM_STREAM_READ_TIMEOUT=300
