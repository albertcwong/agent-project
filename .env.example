# UI / Next.js config. Used by the chat app and API routes.

# Auth0 (see docs/AUTH0_SETUP.md). Set AUTH_DISABLED=true for demo (no login).
AUTH_DISABLED=
NEXT_PUBLIC_AUTH_DISABLED=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

# LLM proxy (for direct chat and /api/models)
LLM_PROXY_URL=http://localhost:8000
LLM_PROXY_API_KEY=
LLM_PROXY_PROVIDER=openai

# Agent API URL (Next.js proxies /api/agent/* and /api/mcp/* to this)
AGENT_API_URL=http://localhost:8001
