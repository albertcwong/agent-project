# Docker overrides. Copy to .env.docker and adjust.
# Use host.docker.internal for services running on the host.

LLM_PROXY_URL=http://host.docker.internal:8000

# Demo mode: bypass auth (NEXT_PUBLIC_* must be set at build time via build args)
# AUTH_DISABLED=true
# NEXT_PUBLIC_AUTH_DISABLED=true

# If MCP servers run on host, use host.docker.internal in .env.agent URLs:
# TABLEAU_MCP_SERVERS='[{"id":"...","url":"http://host.docker.internal:3927/tableau-mcp",...}]'
