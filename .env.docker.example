# Docker overrides. Copy to .env.docker and adjust.
# Use host.docker.internal for services running on the host.

LLM_PROXY_URL=http://host.docker.internal:8000

# Agent API (OAuth callback fetches /mcp/servers). docker-compose sets agent:8001.
# If agent runs on host: AGENT_API_URL=http://host.docker.internal:8001

# Demo mode: bypass auth (NEXT_PUBLIC_* must be set at build time via build args)
# AUTH_DISABLED=true
# NEXT_PUBLIC_AUTH_DISABLED=true

# MCP servers on host: override TABLEAU_MCP_SERVERS with host.docker.internal.
# The OAuth callback runs in the frontend container and must reach the MCP server.
# Uncomment and adjust ports to match your MCP servers:
# TABLEAU_MCP_SERVERS='[{"id":"embark","name":"Embark","url":"http://host.docker.internal:3927/tableau-mcp"},{"id":"analytics","name":"Tableau Analytics","url":"http://host.docker.internal:3929/tableau-mcp"},{"id":"cloud","name":"Tableau Cloud","url":"http://host.docker.internal:3928/tableau-mcp"}]'
